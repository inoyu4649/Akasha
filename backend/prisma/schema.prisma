generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  name          String
  picture       String?
  googleId      String   @unique @map("google_id")
  role          Role     @default(USER)
  dailyCredits  Int      @default(30) @map("daily_credits")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  usageLogs     UsageLog[]
  conversations Conversation[]

  @@map("users")
}

model ModelConfig {
  id         Int      @id @default(autoincrement())
  modelName  String   @unique @map("model_name")
  creditCost Int      @map("credit_cost")
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("model_config")
}

model UsageLog {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  modelName   String   @map("model_name")
  creditsUsed Int      @map("credits_used")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("usage_logs")
}

model Conversation {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  title     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId])
  @@map("conversations")
}

model Message {
  id             Int      @id @default(autoincrement())
  conversationId Int      @map("conversation_id")
  role           String
  content        String   @db.Text
  modelName      String?  @map("model_name")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}
