# ── General ───────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Backend ───────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5174
OLLAMA_URL=http://localhost:11434

# ── Database ───────────────────────────────────────────────────────────────
# dev: URL-encode special chars in password (@ → %40)
DATABASE_URL=mysql://root:password@localhost:3306/akasha
# Docker Compose uses this for the MySQL root password:
MYSQL_ROOT_PASSWORD=change_me_in_production

# ── Google OAuth ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# dev: Vite proxy 경유 (쿠키 도메인 통일) / prod: https://ai.akademiya.kr/api/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:5174/api/auth/google/callback

# ── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production
JWT_REFRESH_SECRET=change_refresh_secret_in_production
